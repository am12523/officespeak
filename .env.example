# --- Provider (default: gemini — free tier) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza...        # free at https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.5-flash

# --- Optional: switch to Anthropic instead ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- General ---
MAX_TOKENS=2048
DATABASE_URL=sqlite:///./officespeak.db
CORS_ORIGINS=*
# Cost accounting (USD per million tokens). Defaults: 0 for gemini free tier.
# PRICE_INPUT_PER_MTOK=0
# PRICE_OUTPUT_PER_MTOK=0
